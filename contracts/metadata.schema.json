{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://castsense.app/schemas/metadata/0.1.0",
  "title": "CastSense Request Metadata",
  "description": "Client to backend metadata payload per spec §7.2",
  "type": "object",
  "required": ["client", "request"],
  "additionalProperties": false,
  "properties": {
    "client": {
      "type": "object",
      "description": "Client device and app information",
      "required": ["platform", "app_version"],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["web"],
          "description": "Client platform"
        },
        "app_version": {
          "type": "string",
          "description": "Semantic version of the app",
          "pattern": "^\\d+\\.\\d+\\.\\d+.*$"
        },
        "device_model": {
          "type": "string",
          "description": "Device model identifier",
          "maxLength": 128
        },
        "locale": {
          "type": "string",
          "description": "User locale (e.g., en-US)",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone identifier (e.g., America/Chicago)",
          "maxLength": 64
        }
      }
    },
    "request": {
      "type": "object",
      "description": "Request-specific parameters",
      "required": ["mode", "capture_type", "capture_timestamp_utc"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["general", "specific"],
          "description": "Analysis mode"
        },
        "target_species": {
          "type": ["string", "null"],
          "description": "Target species for specific mode",
          "maxLength": 64
        },
        "platform_context": {
          "type": "string",
          "enum": ["shore", "kayak", "boat"],
          "description": "User's fishing platform"
        },
        "gear_type": {
          "type": "string",
          "enum": ["spinning", "baitcasting", "fly", "unknown"],
          "description": "Type of fishing gear being used"
        },
        "capture_type": {
          "type": "string",
          "enum": ["photo", "video"],
          "description": "Type of media captured"
        },
        "capture_timestamp_utc": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of capture in UTC"
        }
      }
    },
    "location": {
      "type": "object",
      "description": "GPS location data",
      "required": ["lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude in decimal degrees"
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude in decimal degrees"
        },
        "accuracy_m": {
          "type": "number",
          "minimum": 0,
          "description": "GPS accuracy in meters"
        },
        "altitude_m": {
          "type": "number",
          "description": "Altitude in meters above sea level"
        },
        "heading_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 360,
          "description": "Device heading in degrees (0-360)"
        },
        "speed_mps": {
          "type": "number",
          "minimum": 0,
          "description": "Speed in meters per second"
        }
      }
    },
    "user_constraints": {
      "type": "object",
      "description": "User-specified constraints and preferences",
      "additionalProperties": false,
      "properties": {
        "lures_available": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 64
          },
          "description": "List of lures the user has available"
        },
        "line_test_lb": {
          "type": "number",
          "minimum": 0,
          "maximum": 200,
          "description": "Line test strength in pounds"
        },
        "notes": {
          "type": "string",
          "maxLength": 500,
          "description": "Additional user notes or constraints"
        }
      }
    }
  }
}
