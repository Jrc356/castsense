# CastSense Mobile Environment Variables
# Copy this file to .env and fill in the values
#
# For different environments, create:
#   .env.development  - Local development
#   .env.staging      - Staging builds
#   .env.production   - Production builds
#
# Using react-native-config:
#   https://github.com/luggit/react-native-config

# ─────────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
API_BASE_URL=http://localhost:3000

# API key for authentication
# In development, this can be left empty if backend auth is disabled
API_KEY=your-dev-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Environment Settings
# ─────────────────────────────────────────────────────────────────────────────

# Environment name: development, staging, or production
ENV_NAME=development

# Enable debug features (logging, dev menu, etc.)
DEBUG_ENABLED=true

# Enable analytics tracking
ANALYTICS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Error Reporting (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting (optional)
# SENTRY_DSN=https://your-sentry-dsn
