# CastSense Backend Environment Variables
# Copy this file to .env and fill in the values

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*
BUILD_VERSION=

# Backend request timeout (milliseconds)
BACKEND_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────
# API key for client authentication. Leave empty to disable auth (dev mode only)
API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider Configuration (Required)
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER_API_KEY=your_ai_provider_api_key_here
AI_PROVIDER_BASE_URL=
AI_MODEL=gpt-4o
AI_TWO_STAGE_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Enrichment APIs (Optional for some providers)
# ─────────────────────────────────────────────────────────────────────────────
# Weather API key (optional if using Open-Meteo)
WEATHER_API_KEY=
# Geocode API key (optional)
GEOCODE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Object Storage (Optional - uses ephemeral disk if not set)
# ─────────────────────────────────────────────────────────────────────────────
OBJECT_STORE_BUCKET=
OBJECT_STORE_REGION=

# ─────────────────────────────────────────────────────────────────────────────
# Media Processing
# ─────────────────────────────────────────────────────────────────────────────
MEDIA_TTL_SECONDS=3600
MAX_PHOTO_BYTES=8388608
MAX_VIDEO_BYTES=26214400
MAX_IMAGE_DIMENSION=1920
KEYFRAME_MAX_DIMENSION=1280

# ─────────────────────────────────────────────────────────────────────────────
# Timeouts (milliseconds)
# ─────────────────────────────────────────────────────────────────────────────
ENRICHMENT_TIMEOUT_MS=2000
AI_TIMEOUT_MS_PHOTO=12000
AI_TIMEOUT_MS_VIDEO=18000

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_CONCURRENCY=10

# ─────────────────────────────────────────────────────────────────────────────
# Privacy Controls
# ─────────────────────────────────────────────────────────────────────────────
LOG_LOCATION_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Hydrology API (Optional)
# ─────────────────────────────────────────────────────────────────────────────
HYDROLOGY_API_KEY=
HYDROLOGY_API_URL=
