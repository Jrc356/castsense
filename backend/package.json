{
  "name": "@castsense/backend",
  "version": "0.1.0",
  "description": "CastSense backend orchestration service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:build": "docker build -t castsense-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env castsense-backend",
    "docker:compose": "docker-compose -f ../docker-compose.yml up",
    "docker:compose:build": "docker-compose -f ../docker-compose.yml up --build",
    "docker:compose:dev": "docker-compose -f ../docker-compose.yml -f ../docker-compose.dev.yml up"
  },
  "keywords": [
    "castsense",
    "fishing",
    "ai",
    "backend"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fluent-ffmpeg": "^2.1.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "suncalc": "^1.9.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/suncalc": "^1.9.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
